{
  "manifest_version": 3,
  "name": "Benglishify - Smart Benglish Translator",
  "version": "1.0",
  "description": "Smart Benglish-to-English and English-to-Benglish translator with AI-powered context awareness.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
